apiVersion: v1
kind: Secret
metadata:
  name: insight-claude-admin-main
  namespace: data
  labels:
    app.kubernetes.io/part-of: insight
  annotations:
    insight.cyberfabric.com/connector: claude-admin
    insight.cyberfabric.com/source-id: claude-admin-main
type: Opaque
stringData:
  # Required — Anthropic Admin API key with organization-level read scope.
  # Created at console.anthropic.com by an organization admin.
  admin_api_key: "CHANGE_ME"

  # Optional — earliest date to collect usage / cost / code-usage data from.
  # Accepts full ISO 8601 (e.g. 2026-01-01T00:00:00Z) or date-only (YYYY-MM-DD).
  # Defaults to 90 days ago.
  # start_date: "2026-01-01"

  # Optional — connector instance identifier for multi-instance deployments.
  # Defaults to empty string.
  # insight_source_id: "claude-admin-main"
